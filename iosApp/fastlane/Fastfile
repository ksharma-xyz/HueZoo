# Fastfile for Huezoo iOS App

skip_docs

default_platform(:ios)

platform :ios do
  after_all do |lane|
    cleanup_ci_keychain if is_ci
  end

  error do |lane, exception|
    cleanup_ci_keychain if is_ci
  end

  desc "Build iOS App for Release"
  lane :build_release do
    setup_ci if is_ci

    # Xcode version is selected by maxim-lobanov/setup-xcode in the CI workflow.
    # xcversion is not used — the underlying xcode-install gem is sunsetted and
    # broken on macos-15 runners (fastlane/fastlane#29469).

    # The project has GENERATE_INFOPLIST_FILE = YES, so Xcode generates Info.plist
    # at build time from CURRENT_PROJECT_VERSION — patching the plist file on disk
    # (set_info_plist_value) has no effect. The correct approach is to pass
    # CURRENT_PROJECT_VERSION via xcargs, overriding the hardcoded project value.
    # IOS_BUILD_NUMBER is set by the CI workflow step before this lane runs.
    # Skipped for local builds (IOS_BUILD_NUMBER not set).
    build_number = ENV['IOS_BUILD_NUMBER']
    if build_number.nil? || build_number.empty?
      UI.message("IOS_BUILD_NUMBER not set — using CURRENT_PROJECT_VERSION from xcodeproj (local build).")
      build_number = nil
    end

    # Set provisioning profile ONLY for the iosApp target by modifying the project file.
    # This avoids putting PROVISIONING_PROFILE_SPECIFIER in xcargs, which would bleed
    # into every SPM target and cause "does not support provisioning profiles" errors.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "iosApp.xcodeproj",
      team_id: ENV["DEVELOPMENT_TEAM"],
      bundle_identifier: ENV["APP_BUNDLE_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["PROVISIONING_PROFILE_NAME"],
      targets: ["iosApp"]
    )

    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "iosApp.ipa",
      buildlog_path: "./build/logs",
      clean: true,
      skip_package_dependencies_resolution: true,
      # CURRENT_PROJECT_VERSION overrides the hardcoded value in the xcodeproj so the
      # generated Info.plist gets the correct CFBundleVersion.
      # DEVELOPMENT_TEAM ensures SPM package targets also have a team set.
      # PROVISIONING_PROFILE_SPECIFIER is NOT here — set per-target above.
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "CODE_SIGN_IDENTITY='Apple Distribution'",
        "DEVELOPMENT_TEAM='#{ENV["DEVELOPMENT_TEAM"]}'",
        build_number ? "CURRENT_PROJECT_VERSION=#{build_number}" : nil
      ].compact.join(" "),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          ENV["APP_BUNDLE_ID"] => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do
    # Load API key from APP_STORE_CONNECT_API_KEY_* env vars (set in CI workflow) into lane context.
    # upload_to_testflight then picks it up automatically — no api_key_path needed.
    app_store_connect_api_key
    upload_to_testflight(
      ipa: "./build/iosApp.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Build and Upload to TestFlight"
  lane :release do
    build_release
    upload_testflight
  end
end

# Deletes the temp keychain created by setup_ci so subsequent runs start clean.
# Without this, a failed run leaves the keychain behind and the next run's
# setup_ci call fails because the keychain already exists.
def cleanup_ci_keychain(name = "fastlane_tmp_keychain")
  if File.exist? File.expand_path("~/Library/Keychains/#{name}-db")
    delete_keychain(name: name)
    sh("security default-keychain -s ~/Library/Keychains/login.keychain-db")
  end
end
